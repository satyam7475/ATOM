{
    "deployment": {
        "profile": "corporate_laptop",
        "dashboard_badge": true
    },
    "session": {
        "enabled": true,
        "max_query_snippet_chars": 120
    },
    "skills": {
        "enabled": true,
        "path": "config/skills.json"
    },
    "owner": {
        "name": "Satyam",
        "title": "Boss"
    },
    "vision": {
        "enabled": false,
        "camera_index": 0,
        "check_interval_seconds": 5,
        "require_owner_for_sensitive": false,
        "owner_encoding_path": "config/owner_face.npy"
    },
    "mic": {
        "device_name": null,
        "prefer_bluetooth": true
    },
    "stt": {
        "engine": "faster_whisper",
        "whisper_model_size": "small",
        "bilingual": true,
        "sample_rate": 16000,
        "chunk_size": 2048,
        "post_tts_cooldown_ms": 800,
        "preload": true,
        "calibration_delay_s": 2.0,
        "min_energy_threshold": 400
    },
    "tts": {
        "engine": "edge",
        "max_lines": 4,
        "rate": 2,
        "edge_voice": "en-GB-RyanNeural",
        "edge_rate": "+0%",
        "edge_postprocess": true,
        "edge_ack_cache": true
    },
    "context": {
        "enable_clipboard": true,
        "enable_active_window": true,
        "clipboard_max_chars": 400
    },
    "cache": {
        "max_size": 128,
        "ttl_seconds": 300
    },
    "memory": {
        "graph_db_path": "data/atom_memory.db",
        "max_entries": 500,
        "top_k": 3,
        "semantic_weight": 0.7,
        "v7_scoring": {
            "enabled": true,
            "recency_weight": 0.3,
            "importance_weight": 0.3,
            "success_rate_weight": 0.2,
            "similarity_weight": 0.2
        }
    },
    "brain": {
        "enabled": true,
        "model_path": "models/qwen3-8b-q4_k_m.gguf",
        "n_ctx": 8192,
        "n_threads": 4,
        "n_gpu_layers": -1,
        "n_batch": 512,
        "max_tokens": 512,
        "temperature": 0.7,
        "top_p": 0.9,
        "repeat_penalty": 1.1,
        "timeout_seconds": 30
    },
    "assistant_brain": {
        "active_profile": "brain",
        "restore_persisted_profile": true,
        "persist_active_profile": true,
        "audit_profile_changes": true,
        "quick_replies_enabled": true,
        "quick_replies": {
            "how are you": "I'm good, Boss. Systems nominal and ready.",
            "hello atom": "Yes, Boss? What do you need?",
            "hey atom": "Listening, Boss.",
            "thank you": "Anytime, Boss.",
            "thanks atom": "Happy to help, Boss.",
            "good morning atom": "Good morning, Boss. Ready to work.",
            "good night atom": "Good night, Boss. I'll keep watch.",
            "what's up": "All systems green, Boss. Ready for your command.",
            "are you there": "I'm here, Boss. Always listening.",
            "tell me a joke": "Why do programmers prefer dark mode? Because light attracts bugs.",
            "you're smart": "Thanks Boss, I try my best.",
            "i'm bored": "Want me to open something for you, Boss? Or set a new goal?",
            "what should i do": "Check your goals, Boss. Say 'show goals' to see what's pending.",
            "do you sleep": "I don't sleep, Boss. I'm always ready.",
            "status report": "All systems nominal. CPU cool, memory clean, brain loaded."
        },
        "profiles": {
            "atom": {
                "max_tokens": 256,
                "n_ctx": 4096,
                "n_threads": 4,
                "n_gpu_layers": -1,
                "n_batch": 512,
                "timeout_seconds": 20,
                "extra_stop_sequences": ["\n\nUser:", "\nUser:", "\n\nBoss:"]
            },
            "balanced": {
                "max_tokens": 512,
                "n_ctx": 8192,
                "n_threads": 4,
                "n_gpu_layers": -1,
                "n_batch": 512,
                "timeout_seconds": 30
            },
            "brain": {
                "max_tokens": 768,
                "n_ctx": 16384,
                "n_threads": 4,
                "n_gpu_layers": -1,
                "n_batch": 512,
                "timeout_seconds": 45,
                "temperature": 0.65
            }
        }
    },
    "ui": {
        "mode": "desktop",
        "web_port": 8765,
        "auto_open_browser": false,
        "password_auth_enabled": false
    },
    "executor": {
        "max_workers": 2
    },
    "developer": {
        "role": "Personal AI Operating System",
        "focus": "system management, desktop automation, productivity",
        "project_name": "ATOM OS"
    },
    "security": {
        "mode": "strict",
        "audit_to_file": true,
        "require_confirmation_for": [
            "shutdown_pc", "restart_pc", "logoff", "sleep_pc",
            "empty_recycle_bin", "kill_process", "close_app",
            "open_url", "play_youtube", "lock_screen", "screenshot",
            "move_path", "copy_path", "create_folder"
        ]
    },
    "features": {
        "desktop_control": true,
        "file_ops": true,
        "llm": true,
        "system_analyze": true,
        "web_research": false,
        "online_weather": false,
        "proactive_awareness": true
    },
    "control": {
        "lock_mode": "off",
        "assistant_mode": "hybrid",
        "allow_runtime_mode_switch": true,
        "persist_assistant_mode": true,
        "restore_persisted_assistant_mode": true,
        "audit_assistant_mode_changes": true,
        "command_only_message": "Command-only mode is on, Boss — no chat brain for open questions. Try time, cpu, open notepad, or say hybrid mode to bring the brain back."
    },
    "performance": {
        "mode": "auto",
        "auto_threshold_high": 70,
        "auto_threshold_mid": 40,
        "health_check_interval_s": 120,
        "stuck_state_threshold_s": 75,
        "system_watcher_interval_s": 30,
        "maintenance_interval_s": 180,
        "proactive_alerts": false,
        "idle_reminder": false,
        "cpu_governor": true,
        "cpu_governor_threshold": 75,
        "watchdog_thinking_timeout_s": 120,
        "watchdog_speaking_timeout_s": 300,
        "supervisor_restart_cooldown_s": 8,
        "watchdog_poll_interval_s": 2,
        "use_priority_scheduler": true
    },
    "autonomy": {
        "enabled": true,
        "auto_execute_threshold": 0.95,
        "suggest_threshold": 0.72,
        "idle_timeout_minutes": 10,
        "habit_decay_days": 7,
        "habit_decay_rate": 0.02,
        "max_habits": 50,
        "check_interval_s": 90,
        "log_all_decisions": true
    },
    "cognitive": {
        "enabled": true,
        "goals_enabled": true,
        "predictions_enabled": true,
        "behavior_model_enabled": true,
        "self_optimizer_enabled": true,
        "prediction_check_interval_s": 120,
        "behavior_update_interval_s": 900,
        "goal_evaluation_interval_s": 3600,
        "prediction_min_confidence": 0.6,
        "auto_mode_switching": true,
        "default_mode": "work",
        "max_goals": 20,
        "max_predictions": 5,
        "optimizer_check_interval_s": 1800,
        "energy_inference_interval_s": 120,
        "dream_enabled": true,
        "dream_idle_minutes": 30,
        "dream_interval_hours": 6,
        "curiosity_enabled": true,
        "curiosity_max_per_hour": 2,
        "curiosity_cooldown_minutes": 15
    },
    "conversation_memory": {
        "max_turns": 20
    },
    "embedding": {
        "model": "all-MiniLM-L6-v2",
        "dimension": 384,
        "device": "cpu"
    },
    "vector_store": {
        "path": "data/vector_db",
        "backend": "chroma"
    },
    "documents": {
        "chunk_size": 500,
        "chunk_overlap": 50
    },
    "reasoning": {
        "max_plan_steps": 10,
        "max_retries": 2
    },
    "sandbox": {
        "enabled": true,
        "timeout_seconds": 5,
        "max_output_chars": 2000
    },
    "workflow": {
        "max_workflows": 50,
        "max_steps_per_workflow": 30
    },
    "wake_word": {
        "enabled": false,
        "sensitivity": 0.6
    },
    "emotion": {
        "enabled": true
    },
    "screen_reader": {
        "enabled": true
    },
    "gpu": {
        "enabled": true,
        "thermal_threshold": 85,
        "memory_threshold_pct": 90,
        "poll_interval_s": 30
    },
    "v7_intelligence": {
        "default_mode": "SMART",
        "auto_mode": true,
        "mode_stability_enabled": true,
        "simple_query_max_chars": 48,
        "timeline_max_events": 500,
        "max_timeline_size": 500,
        "timeline_summarize_on_prune": false,
        "prediction_prefetch_enabled": true,
        "gpu_util_fast_threshold": 92,
        "deep_query_min_chars": 140,
        "prefer_secure_when_paranoid_ui": false,
        "secure_rag_budget_factor": 0.75,
        "cpu_force_fast_above": 88,
        "cpu_idle_deep_below": 28,
        "low_prediction_accuracy_deep_threshold": 0.35,
        "mode_stability": {
            "cooldown_turns": 3,
            "significant_cpu_delta": 12.0,
            "significant_gpu_delta": 15.0
        },
        "observability": {
            "debug_snapshot_interval_s": 120.0,
            "debug_snapshot_cache_ttl_s": 3.0
        },
        "prefetch": {
            "max_prefetch_candidates": 12,
            "hard_abort_gpu_above": 98.0,
            "soft_scale_gpu_above": 85.0,
            "soft_scale_factor": 0.55,
            "soft_delay_s": 0.25,
            "gpu_soft_extra_delay_s": 0.2,
            "min_prediction_confidence": 0.22,
            "low_conf_extra_delay_s": 0.15
        },
        "feedback": {
            "max_records": 2000,
            "learn_rate": 0.04,
            "rolling_window_50": 50,
            "rolling_window_100": 100,
            "trend_flat_epsilon": 0.04,
            "min_query_chars": 4,
            "learn_confidence_threshold": 0.35
        },
        "health": {
            "prediction_good_above": 0.55,
            "prediction_poor_below": 0.38,
            "prediction_unstable_low": 0.4,
            "prediction_unstable_high": 0.52,
            "prefetch_good_above": 0.35,
            "prefetch_poor_below": 0.15,
            "memory_relevance_good_above": 0.35,
            "memory_relevance_poor_below": 0.15,
            "system_load_cpu_low_below": 55.0,
            "system_load_cpu_high_above": 88.0,
            "system_load_ram_high_above": 90.0
        },
        "warnings": {
            "warn_on_degrading_prediction": true,
            "graph_miss_rate_above": 0.35,
            "prefetch_waste_above": 0.72
        },
        "preemption": {
            "restart_cost": 0.45,
            "relevance_scale": 1.0,
            "context_scale": 0.25,
            "min_improvement_score": 0.25,
            "max_preemptions_per_query": 2
        }
    },
    "rag": {
        "enabled": true,
        "prefetch_enabled": true,
        "first_token_budget_ms": 120,
        "graph_first": {
            "enabled": true,
            "min_confidence": 0.68,
            "min_snippets": 2,
            "project_boost": 0.12,
            "relevance_validation_min": 0.74
        }
    },
    "v7_gpu": {
        "enabled": true,
        "strict_control": false,
        "deployment_mode": "distributed",
        "vram_reserve_mb": 512,
        "model_slots_mb": {
            "llm": 8192,
            "stt": 3072,
            "embeddings": 512
        },
        "eviction_order": ["embeddings", "stt", "llm"],
        "idle_unload_stt_s": 60,
        "idle_unload_llm_s": 180,
        "idle_sleep_s": 600,
        "fused_gpu_worker": false,
        "gpu_stall_timeout_s": 120,
        "allow_cuda_reset": false,
        "degradation_default": "full",
        "event_replay_max": 32,
        "speculative_response": false,
        "simulation_mode": "hybrid"
    }
}
