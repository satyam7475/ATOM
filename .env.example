# ATOM — optional env template (offline build has no cloud API keys).
#
# You may still use a private env file for future integrations:
#
#   %USERPROFILE%\.atom\env
#   or  set ATOM_ENV_FILE=C:\path\to\your\secrets.env
#
# Developer only (never commit secrets):
#   set ATOM_ALLOW_DOTENV=1  and create .env locally
